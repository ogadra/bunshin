# Host port mappings for docker compose services.
# Copy this file to .env and adjust as needed.
NGINX_PORT=80
BROKER_PORT=8080

# Nginx runtime stack settings used by local integration.
STACK_NAME=ap-northeast-1
# ブラウザから preview iframe を動かす demo 時は localhost に置き換える。
# ブラウザは *.localhost を DNS 設定なしで 127.0.0.1 に解決する。
# integration profile は internal.test 前提のため demo 時は integration を使わない。
INTERNAL_DOMAIN=internal.test
BUNSHIN_STACKS=ap-northeast-1,ap-northeast-3
RUNNER_PORT=3000
RUNNER_APP_PORT=5000
TF_BACKEND_BUCKET=terraform-state
