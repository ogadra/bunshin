# broker (firestore backend)
BUNSHIN_STORE=firestore
STACK_NAME=asia-northeast1
# FIRESTORE_EMULATOR_HOST を設定すると SDK が emulator に接続する (production では unset)。
FIRESTORE_EMULATOR_HOST=firestore-emulator:8080
GOOGLE_CLOUD_PROJECT=bunshin-firestore-test
FIRESTORE_DATABASE=(default)
BUNSHIN_STACKS=asia-northeast1,asia-northeast2
# RUNNER_API_PORT is required. broker healthchecks each runner at http://<privateHost>:<RUNNER_API_PORT>/health.
RUNNER_API_PORT=3000
