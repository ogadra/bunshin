# broker
# BUNSHIN_STORE selects the runner Repository backend. dynamodb / firestore.
BUNSHIN_STORE=dynamodb
# STACK_NAME identifies this broker's own stack. Must be listed in BUNSHIN_STACKS.
STACK_NAME=ap-northeast-1
# DYNAMODB_ENDPOINT is optional. If omitted, the SDK uses the default AWS endpoint.
DYNAMODB_ENDPOINT=http://dynamodb-local:8000
# AWS_REGION is required when BUNSHIN_STORE=dynamodb.
AWS_REGION=ap-northeast-1
# AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY are optional.
# If omitted, the SDK uses IAM Role credentials (e.g. ECS task role).
# Both must be set or both must be empty.
AWS_ACCESS_KEY_ID=localdev
AWS_SECRET_ACCESS_KEY=localdev
# BUNSHIN_STACKS is required. Comma-separated list of all stacks and shared by every region (same value).
BUNSHIN_STACKS=ap-northeast-1,ap-northeast-3
