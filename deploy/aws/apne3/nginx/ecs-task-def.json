{
  "family": "bunshin-nginx",
  "requiresCompatibilities": ["FARGATE"],
  "networkMode": "awsvpc",
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "{{ tfstatef `module.apne3.aws_iam_role.ecs_task_execution[%q].arn` `nginx` }}",
  "taskRoleArn": "{{ tfstatef `module.apne3.aws_iam_role.task[%q].arn` `nginx` }}",
  "runtimePlatform": {
    "cpuArchitecture": "ARM64",
    "operatingSystemFamily": "LINUX"
  },
  "containerDefinitions": [
    {
      "name": "nginx",
      "image": "{{ tfstate `data.aws_caller_identity.current.account_id` }}.dkr.ecr.ap-northeast-3.amazonaws.com/bunshin/nginx:{{ must_env `IMAGE_TAG` }}",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "STACK_NAME", "value": "ap-northeast-3" },
        { "name": "INTERNAL_DOMAIN", "value": "{{ tfstate `output.domain_name` }}" },
        { "name": "BUNSHIN_STACKS", "value": "{{ must_env `BUNSHIN_STACKS` }}" },
        { "name": "RUNNER_APP_PORT", "value": "5000" },
        { "name": "CLOUD", "value": "AWS" },
        { "name": "NGINX_RESOLVER", "value": "169.254.169.253" },
        { "name": "BROKER_HOST", "value": "broker.internal" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "{{ tfstatef `module.apne3.aws_cloudwatch_log_group.ecs[%q].name` `nginx` }}",
          "awslogs-region": "ap-northeast-3",
          "awslogs-stream-prefix": "nginx"
        }
      }
    }
  ],
  "tags": [
    { "key": "Project", "value": "Bunshin" },
    { "key": "ManagedBy", "value": "ecspresso" },
    { "key": "Service", "value": "nginx" }
  ]
}
