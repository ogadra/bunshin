domain_name = "example.bunshin.dev"
alb_certificate_arns = {
  apne1 = "arn:aws:acm:ap-northeast-1:123456789012:certificate/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
  apne3 = "arn:aws:acm:ap-northeast-3:123456789012:certificate/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
}
cloudfront_certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
aws_profile                = "bunshin-dev"
runner_desired_count       = 300
proxy_secret               = "proxy_secret"
